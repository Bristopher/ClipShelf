{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipShelf",
  "version": "2.0.17",
  "identifier": "com.cbuzi.gkey-mover-v2",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1499",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClipShelf",
        "width": 900,
        "height": 260,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "visible": false,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Bristopher",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  }
}
